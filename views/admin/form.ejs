<%
  const certs = (product && product.certificates) ? product.certificates : [];
%>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= product ? 'Edit Product — ' + product.model : 'New Product' %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen">

  <header class="bg-white border-b sticky top-0 z-10">
    <div class="max-w-2xl mx-auto px-4 py-3 flex items-center justify-between gap-3">
      <div class="flex items-center gap-3">
        <a href="/admin" class="text-gray-400 hover:text-gray-600 text-sm">← Back</a>
        <h1 class="text-sm font-semibold text-gray-800">
          <%= product ? 'Edit Product — ' + product.model : 'New Product' %>
        </h1>
      </div>
      <form method="POST" action="/logout">
        <button type="submit"
                class="text-xs border border-gray-300 text-gray-600 px-3 py-1.5 rounded-lg hover:bg-gray-50 transition-colors">
          Logout
        </button>
      </form>
    </div>
  </header>

  <main class="max-w-2xl mx-auto px-4 py-6">
    <% if (error) { %>
    <div class="mb-4 bg-red-50 border border-red-200 text-red-700 text-sm px-4 py-3 rounded-xl">
      <%= error %>
    </div>
    <% } %>

    <form id="product-form" method="POST" action="<%= action %>" enctype="multipart/form-data" class="space-y-6">

      <section class="bg-white rounded-2xl shadow-sm p-5 space-y-4">
        <h2 class="text-sm font-semibold text-gray-700 border-b pb-2">Basic Information</h2>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs text-gray-500 mb-1">Product Model <span class="text-red-400">*</span></label>
            <input type="text" name="model" required
                   value="<%= product ? product.model : '' %>"
                   <%= product ? 'readonly class="w-full border border-gray-200 bg-gray-50 rounded-lg px-3 py-2 text-sm text-gray-500"' : 'class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300"' %>
                   placeholder="e.g. FC789-1">
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Product Image</label>
            <input type="file" name="productImage" accept="image/*"
                   class="w-full text-sm text-gray-500 file:mr-2 file:py-1 file:px-3 file:rounded file:border-0 file:text-xs file:bg-blue-50 file:text-blue-600 hover:file:bg-blue-100">
            <% if (product && product.image) { %>
            <p class="current-file text-xs text-gray-400 mt-1">Current: <%= product.image %></p>
            <% } %>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs text-gray-500 mb-1">Product Name (EN)</label>
            <input type="text" name="nameEn"
                   value="<%= product ? product.nameEn : '' %>"
                   class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300"
                   placeholder="Hair Clipper">
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Company Name (EN)</label>
            <input type="text" name="companyEn"
                   value="<%= product ? product.companyEn : '' %>"
                   class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300"
                   placeholder="Wenzhou Hongye Fitness Equipment Co., Ltd.">
          </div>
        </div>

        <div>
          <label class="block text-xs text-gray-500 mb-1">Address (EN)</label>
          <input type="text" name="addressEn"
                 value="<%= product ? product.addressEn : '' %>"
                 class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300"
                 placeholder="No.254, Zhangge Village, Wanquan Town, Pingyang County, Wenzhou, Zhejiang, China">
        </div>
      </section>

      <section class="bg-white rounded-2xl shadow-sm p-5 space-y-4">
        <h2 class="text-sm font-semibold text-gray-700 border-b pb-2">Product Specs</h2>

        <div class="grid grid-cols-3 gap-3">
          <div>
            <label class="block text-xs text-gray-500 mb-1">Battery</label>
            <input type="text" name="params.battery" value="<%= product ? product.params.battery : '' %>"
                   class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300"
                   placeholder="1200 mAh">
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Max Power</label>
            <input type="text" name="params.power" value="<%= product ? product.params.power : '' %>"
                   class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300"
                   placeholder="5 W">
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Motor Speed</label>
            <input type="text" name="params.speed" value="<%= product ? product.params.speed : '' %>"
                   class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300"
                   placeholder="6000 RPM">
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs text-gray-500 mb-1">Blade Material (EN)</label>
            <input type="text" name="params.bladeEn" value="<%= product ? product.params.bladeEn : '' %>"
                   class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300"
                   placeholder="3Cr13 Stainless Steel">
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Charging Port</label>
            <input type="text" name="params.port" value="<%= product ? product.params.port : '' %>"
                   class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300"
                   placeholder="Type-C">
          </div>
        </div>

        <div class="grid grid-cols-3 gap-3">
          <div>
            <label class="block text-xs text-gray-500 mb-1">Charging Time</label>
            <input type="text" name="params.chargingTime" value="<%= product ? product.params.chargingTime : '' %>"
                   class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300"
                   placeholder="5 hours">
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Usage Time</label>
            <input type="text" name="params.usageTime" value="<%= product ? product.params.usageTime : '' %>"
                   class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300"
                   placeholder="6-8 hours">
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Production Date</label>
            <input type="text" name="params.productionDate" value="<%= product ? product.params.productionDate : '' %>"
                   class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300"
                   placeholder="Pending">
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Weight</label>
            <input type="text" name="params.weight" value="<%= product ? product.params.weight : '' %>"
                   class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300"
                   placeholder="141.2 g">
          </div>
        </div>
      </section>

      <section class="bg-white rounded-2xl shadow-sm p-5 space-y-4">
        <h2 class="text-sm font-semibold text-gray-700 border-b pb-2">Packaging</h2>
        <div class="grid grid-cols-3 gap-3">
          <div>
            <label class="block text-xs text-gray-500 mb-1">Package Size</label>
            <input type="text" name="pkg.size" value="<%= product ? product.pkg.size : '' %>"
                   class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300"
                   placeholder="12.8×52.5×20 cm">
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Carton Qty (EN)</label>
            <input type="text" name="pkg.qtyEn" value="<%= product ? product.pkg.qtyEn : '' %>"
                   class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300"
                   placeholder="80 pcs/ctn">
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Carton Size</label>
            <input type="text" name="pkg.carton" value="<%= product ? product.pkg.carton : '' %>"
                   class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300"
                   placeholder="55×41.5×53.5 cm">
          </div>
        </div>
      </section>

      <section class="bg-white rounded-2xl shadow-sm p-5 space-y-4">
        <h2 class="text-sm font-semibold text-gray-700 border-b pb-2">Patent Information</h2>

        <div class="grid grid-cols-3 gap-3">
          <div>
            <label class="block text-xs text-gray-500 mb-1">Patent No.</label>
            <input type="text" name="patent.no" value="<%= product ? product.patent.no : '' %>"
                   class="w-full border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-blue-300"
                   placeholder="ZL 2025 3 0594617.X">
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Publication No.</label>
            <input type="text" name="patent.pubNo" value="<%= product ? product.patent.pubNo : '' %>"
                   class="w-full border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-blue-300"
                   placeholder="CN 309606064 S">
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Certificate No. (EN)</label>
            <input type="text" name="patent.certNoEn" value="<%= product ? product.patent.certNoEn : '' %>"
                   class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300"
                   placeholder="No. 9621776">
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs text-gray-500 mb-1">Patentee (EN)</label>
            <input type="text" name="patent.ownerEn" value="<%= product ? product.patent.ownerEn : '' %>"
                   class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300"
                   placeholder="Wenzhou Hongye Fitness Equipment Co., Ltd.">
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Patent Name (EN)</label>
            <input type="text" name="patent.nameEn" value="<%= product ? product.patent.nameEn : '' %>"
                   class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300"
                   placeholder="Hair Clipper (Industrial Design)">
          </div>
        </div>

        <div class="grid grid-cols-3 gap-3">
          <div>
            <label class="block text-xs text-gray-500 mb-1">Designer (EN)</label>
            <input type="text" name="patent.designerEn" value="<%= product ? product.patent.designerEn : '' %>"
                   class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300"
                   placeholder="e.g. Cai Yingying">
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Application Date</label>
            <input type="text" name="patent.applyDate" value="<%= product ? product.patent.applyDate : '' %>"
                   class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300"
                   placeholder="2025-10-10">
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Publication Date</label>
            <input type="text" name="patent.pubDate" value="<%= product ? product.patent.pubDate : '' %>"
                   class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300"
                   placeholder="2025-11-14">
          </div>
        </div>

        <div class="grid grid-cols-3 gap-3">
          <div class="col-span-2">
            <label class="block text-xs text-gray-500 mb-1">Issuing Authority (EN)</label>
            <input type="text" name="patent.issuerEn" value="<%= product ? product.patent.issuerEn : '' %>"
                   class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300"
                   placeholder="China National Intellectual Property Administration">
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Evaluation Report Date</label>
            <input type="text" name="patent.evalDate" value="<%= product ? product.patent.evalDate : '' %>"
                   class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300"
                   placeholder="2025-12-19">
          </div>
        </div>
      </section>

      <section class="bg-white rounded-2xl shadow-sm p-5 space-y-4">
        <h2 class="text-sm font-semibold text-gray-700 border-b pb-2">Certificate Attachments</h2>
        <p class="text-xs text-gray-400">One certificate per row. Fill the English name and upload the PDF and thumbnail.</p>

        <div id="cert-list" class="space-y-4">
          <% certs.forEach(function(cert, i) { %>
          <div class="cert-item border rounded-xl p-4 space-y-3 relative">
            <button type="button" onclick="removeCert(this)"
                    class="absolute top-3 right-3 text-xs text-red-400 hover:text-red-600">✕</button>
            <input type="hidden" name="certs[<%= i %>][file]" value="<%= cert.file %>">
            <input type="hidden" name="certs[<%= i %>][thumb]" value="<%= cert.thumb %>">

            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-xs text-gray-500 mb-1">Certificate Name (EN)</label>
                <input type="text" name="certs[<%= i %>][nameEn]"
                       value="<%= cert.nameEn %>"
                       class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300">
              </div>
              <div>
                <label class="block text-xs text-gray-500 mb-1">Date</label>
                <input type="text" name="certs[<%= i %>][date]"
                       value="<%= cert.date %>"
                       class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300"
                       placeholder="2025-11-14">
              </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-xs text-gray-500 mb-1">PDF File</label>
                <input type="file" name="certFiles[<%= i %>]" accept=".pdf"
                       class="w-full text-xs text-gray-500 file:mr-1 file:py-1 file:px-2 file:rounded file:border-0 file:text-xs file:bg-blue-50 file:text-blue-600">
                <% if (cert.file) { %><p class="current-file text-xs text-gray-400 mt-0.5 truncate">Current: <%= cert.file %></p><% } %>
              </div>
              <div>
                <label class="block text-xs text-gray-500 mb-1">Thumbnail</label>
                <input type="file" name="certThumbs[<%= i %>]" accept="image/*"
                       class="w-full text-xs text-gray-500 file:mr-1 file:py-1 file:px-2 file:rounded file:border-0 file:text-xs file:bg-blue-50 file:text-blue-600">
                <% if (cert.thumb) { %><p class="current-file text-xs text-gray-400 mt-0.5 truncate">Current: <%= cert.thumb %></p><% } %>
              </div>
            </div>
          </div>
          <% }); %>
        </div>

        <input type="hidden" id="cert-count" name="certCount" value="<%= certs.length %>">

        <button type="button" onclick="addCert()"
                class="text-xs border border-dashed border-gray-300 text-gray-500 hover:border-blue-400 hover:text-blue-500 w-full py-2 rounded-xl transition-colors">
          + Add Certificate
        </button>
      </section>

      <div class="flex gap-3">
        <button type="submit"
                class="flex-1 bg-blue-500 text-white text-sm font-medium py-3 rounded-xl hover:bg-blue-600 transition-colors">
          Save
        </button>
        <a href="/admin"
           class="px-6 py-3 border border-gray-300 text-gray-500 text-sm rounded-xl hover:bg-gray-50 transition-colors">
          Cancel
        </a>
      </div>

    </form>
  </main>

  <script>
    let certCount = parseInt(document.getElementById('cert-count').value, 10);

    function renderCertItem(i) {
      return `
        <button type="button" onclick="removeCert(this)"
                class="absolute top-3 right-3 text-xs text-red-400 hover:text-red-600">✕</button>
        <input type="hidden" name="certs[${i}][file]" value="">
        <input type="hidden" name="certs[${i}][thumb]" value="">
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs text-gray-500 mb-1">Certificate Name (EN)</label>
            <input type="text" name="certs[${i}][nameEn]"
                   class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300">
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Date</label>
            <input type="text" name="certs[${i}][date]"
                   class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300"
                   placeholder="2025-11-14">
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs text-gray-500 mb-1">PDF File</label>
            <input type="file" name="certFiles[${i}]" accept=".pdf"
                   class="w-full text-xs text-gray-500 file:mr-1 file:py-1 file:px-2 file:rounded file:border-0 file:text-xs file:bg-blue-50 file:text-blue-600">
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Thumbnail</label>
            <input type="file" name="certThumbs[${i}]" accept="image/*"
                   class="w-full text-xs text-gray-500 file:mr-1 file:py-1 file:px-2 file:rounded file:border-0 file:text-xs file:bg-blue-50 file:text-blue-600">
          </div>
        </div>
      `;
    }

    function addCert() {
      const div = document.createElement('div');
      div.className = 'cert-item border rounded-xl p-4 space-y-3 relative';
      div.innerHTML = renderCertItem(certCount);
      document.getElementById('cert-list').appendChild(div);
      certCount += 1;
      document.getElementById('cert-count').value = certCount;
    }

    function removeCert(btn) {
      btn.closest('.cert-item').remove();
      document.querySelectorAll('#cert-list .cert-item').forEach((item, idx) => {
        item.querySelectorAll('[name]').forEach((el) => {
          el.name = el.name
            .replace(/certs\[\d+\]/, `certs[${idx}]`)
            .replace(/certFiles\[\d+\]/, `certFiles[${idx}]`)
            .replace(/certThumbs\[\d+\]/, `certThumbs[${idx}]`);
        });
      });
      certCount = document.querySelectorAll('#cert-list .cert-item').length;
      document.getElementById('cert-count').value = certCount;
    }

  </script>
</body>
</html>
