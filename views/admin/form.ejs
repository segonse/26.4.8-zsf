    let certCount = parseInt(document.getElementById('cert-count').value, 10);
    let currentLang = 'en';

    function getNamedElements(name) {
      return document.getElementsByName(name);
    }

    function getFirstNamedElement(name) {
      return getNamedElements(name)[0] || null;
    }

    function setFieldLabel(name, text, required) {
      const input = getFirstNamedElement(name);
      if (!input) return;
      const label = input.parentElement.querySelector('label');
      if (!label) return;
      label.innerHTML = required
        ? `${text} <span class="text-red-400">*</span>`
        : text;
    }

    function setPlaceholder(name, text) {
      const input = getFirstNamedElement(name);
      if (input && text !== undefined) input.placeholder = text;
    }

    function updateCurrentFileLabels(lang) {
      document.querySelectorAll('.current-file').forEach(el => {
        el.textContent = `${i18n[lang].currentPrefix} ${el.dataset.path}`;
      });
    }

    function updateCertItemLabels(item, lang) {
      const labels = item.querySelectorAll('label');
      if (labels.length < 5) return;
      labels[0].textContent = i18n[lang].certLabels.nameZh;
      labels[1].textContent = i18n[lang].certLabels.nameEn;
      labels[2].textContent = i18n[lang].certLabels.date;
      labels[3].textContent = i18n[lang].certLabels.file;
      labels[4].textContent = i18n[lang].certLabels.thumb;
    }

    function switchLang(lang) {
      currentLang = lang;
      localStorage.setItem('lang', lang);
      document.documentElement.lang = lang === 'zh' ? 'zh-CN' : 'en';
      document.title = i18n[lang].title;

      document.getElementById('back-link').textContent = i18n[lang].back;
      document.getElementById('form-title').textContent = i18n[lang].title;
      document.getElementById('section-basic').textContent = i18n[lang].sectionBasic;
      document.getElementById('section-params').textContent = i18n[lang].sectionParams;
      document.getElementById('section-pkg').textContent = i18n[lang].sectionPkg;
      document.getElementById('section-patent').textContent = i18n[lang].sectionPatent;
      document.getElementById('section-cert').textContent = i18n[lang].sectionCert;
      document.getElementById('cert-help').textContent = i18n[lang].certHelp;
      document.getElementById('add-cert-button').textContent = i18n[lang].addCert;
      document.getElementById('save-button').textContent = i18n[lang].save;
      document.getElementById('cancel-link').textContent = i18n[lang].cancel;
      document.getElementById('logout-button').textContent = i18n[lang].logout;

      setFieldLabel('model', i18n[lang].fieldLabels.model, true);
      setFieldLabel('productImage', i18n[lang].fieldLabels.productImage, false);
      setFieldLabel('name', i18n[lang].fieldLabels.name, false);
      setFieldLabel('nameEn', i18n[lang].fieldLabels.nameEn, false);
      setFieldLabel('company', i18n[lang].fieldLabels.company, false);
      setFieldLabel('companyEn', i18n[lang].fieldLabels.companyEn, false);
      setFieldLabel('address', i18n[lang].fieldLabels.address, false);
      setFieldLabel('addressEn', i18n[lang].fieldLabels.addressEn, false);
      setFieldLabel('params.battery', i18n[lang].fieldLabels['params.battery'], false);
      setFieldLabel('params.power', i18n[lang].fieldLabels['params.power'], false);
      setFieldLabel('params.speed', i18n[lang].fieldLabels['params.speed'], false);
      setFieldLabel('params.blade', i18n[lang].fieldLabels['params.blade'], false);
      setFieldLabel('params.bladeEn', i18n[lang].fieldLabels['params.bladeEn'], false);
      setFieldLabel('params.port', i18n[lang].fieldLabels['params.port'], false);
      setFieldLabel('params.chargingTime', i18n[lang].fieldLabels['params.chargingTime'], false);
      setFieldLabel('params.productionDate', i18n[lang].fieldLabels['params.productionDate'], false);
      setFieldLabel('params.weight', i18n[lang].fieldLabels['params.weight'], false);
      setFieldLabel('params.dimensions', i18n[lang].fieldLabels['params.dimensions'], false);
      setFieldLabel('params.dimensionsUnit', i18n[lang].fieldLabels['params.dimensionsUnit'], false);
      setFieldLabel('pkg.size', i18n[lang].fieldLabels['pkg.size'], false);
      setFieldLabel('pkg.qty', i18n[lang].fieldLabels['pkg.qty'], false);
      setFieldLabel('pkg.qtyEn', i18n[lang].fieldLabels['pkg.qtyEn'], false);
      setFieldLabel('pkg.carton', i18n[lang].fieldLabels['pkg.carton'], false);
      setFieldLabel('patent.no', i18n[lang].fieldLabels['patent.no'], false);
      setFieldLabel('patent.pubNo', i18n[lang].fieldLabels['patent.pubNo'], false);
      setFieldLabel('patent.certNo', i18n[lang].fieldLabels['patent.certNo'], false);
      setFieldLabel('patent.certNoEn', i18n[lang].fieldLabels['patent.certNoEn'], false);
      setFieldLabel('patent.owner', i18n[lang].fieldLabels['patent.owner'], false);
      setFieldLabel('patent.name', i18n[lang].fieldLabels['patent.name'], false);
      setFieldLabel('patent.nameEn', i18n[lang].fieldLabels['patent.nameEn'], false);
      setFieldLabel('patent.designer', i18n[lang].fieldLabels['patent.designer'], false);
      setFieldLabel('patent.applyDate', i18n[lang].fieldLabels['patent.applyDate'], false);
      setFieldLabel('patent.pubDate', i18n[lang].fieldLabels['patent.pubDate'], false);
      setFieldLabel('patent.issuer', i18n[lang].fieldLabels['patent.issuer'], false);
      setFieldLabel('patent.issuerEn', i18n[lang].fieldLabels['patent.issuerEn'], false);
      setFieldLabel('patent.evalDate', i18n[lang].fieldLabels['patent.evalDate'], false);

      Object.entries(i18n[lang].placeholders).forEach(([name, text]) => {
        setPlaceholder(name, text);
      });

      document.querySelectorAll('.cert-item').forEach(item => updateCertItemLabels(item, lang));
      updateCurrentFileLabels(lang);

      const isZh = lang === 'zh';
      const btnZh = document.getElementById('btn-zh');
      const btnEn = document.getElementById('btn-en');
      btnZh.classList.toggle('font-semibold', isZh);
      btnZh.classList.toggle('border-blue-400', isZh);
      btnZh.classList.toggle('text-blue-500', isZh);
      btnEn.classList.toggle('font-semibold', !isZh);
      btnEn.classList.toggle('border-blue-400', !isZh);
      btnEn.classList.toggle('text-blue-500', !isZh);
    }

    function updateCertCount() {
      document.getElementById('cert-count').value = certCount;
    }

    function renderCertItem(i) {
      const labels = i18n[currentLang].certLabels;
      return `
        <button type="button" onclick="removeCert(this)"
                class="absolute top-3 right-3 text-xs text-red-400 hover:text-red-600">✕</button>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs text-gray-500 mb-1">${labels.nameZh}</label>
            <input type="text" name="certs[${i}][nameZh]"
                   class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300">
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">${labels.nameEn}</label>
            <input type="text" name="certs[${i}][nameEn]"
                   class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300">
          </div>
        </div>
        <div class="grid grid-cols-3 gap-3">
          <div>
            <label class="block text-xs text-gray-500 mb-1">${labels.date}</label>
            <input type="text" name="certs[${i}][date]"
                   class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300"
                   placeholder="2025-11-14">
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">${labels.file}</label>
            <input type="file" name="certFiles" accept=".pdf"
                   class="w-full text-xs text-gray-500 file:mr-1 file:py-1 file:px-2 file:rounded file:border-0 file:text-xs file:bg-blue-50 file:text-blue-600">
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">${labels.thumb}</label>
            <input type="file" name="certThumbs" accept="image/*"
                   class="w-full text-xs text-gray-500 file:mr-1 file:py-1 file:px-2 file:rounded file:border-0 file:text-xs file:bg-blue-50 file:text-blue-600">
          </div>
        </div>
        <input type="hidden" name="certs[${i}][file]" value="">
        <input type="hidden" name="certs[${i}][thumb]" value="">
      `;
    }

    function addCert() {
      const i = certCount;
      const div = document.createElement('div');
      div.className = 'cert-item border rounded-xl p-4 space-y-3 relative';
      div.innerHTML = renderCertItem(i);
      document.getElementById('cert-list').appendChild(div);
      certCount++;
      updateCertCount();
      switchLang(currentLang);
    }

    function removeCert(btn) {
      btn.closest('.cert-item').remove();
      // 重新编号 cert-items 中的 name 属性
      document.querySelectorAll('#cert-list .cert-item').forEach((item, idx) => {
        item.querySelectorAll('[name]').forEach(el => {
          el.name = el.name.replace(/certs\[\d+\]/, `certs[${idx}]`);
        });
      });
      certCount = document.querySelectorAll('#cert-list .cert-item').length;
      updateCertCount();
    }

    (function () {
      const urlLang = new URLSearchParams(location.search).get('lang');
      const savedLang = localStorage.getItem('lang');
      switchLang(urlLang || savedLang || 'en');
    })();
  </script>
