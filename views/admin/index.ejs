<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>产品管理后台</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen">

  <header class="bg-white border-b sticky top-0 z-10">
    <div class="max-w-3xl mx-auto px-4 py-3 flex items-center justify-between">
      <div>
        <h1 class="text-sm font-semibold text-gray-800">产品管理后台</h1>
        <p class="text-xs text-gray-400 mt-0.5">内部使用 · 请勿分享给外部人员</p>
      </div>
      <a href="/admin/new"
         class="text-xs bg-blue-500 text-white px-3 py-1.5 rounded-lg hover:bg-blue-600 transition-colors">
        + 新增产品
      </a>
    </div>
  </header>

  <main class="max-w-3xl mx-auto px-4 py-6 space-y-6">

    <!-- NFC 域名配置 -->
    <section class="bg-white rounded-2xl shadow-sm p-5">
      <h2 class="text-sm font-semibold text-gray-700 mb-3">NFC 标签 URL</h2>
      <div class="flex gap-2 items-center">
        <input id="domain-input" type="text" placeholder="https://你的域名"
               class="flex-1 border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300">
        <span class="text-xs text-gray-400">修改后下方链接自动更新</span>
      </div>
    </section>

    <!-- 产品列表 -->
    <% if (products.length === 0) { %>
    <div class="text-center py-16 text-gray-400 text-sm">
      暂无产品数据，点击右上角"+ 新增产品"开始录入
    </div>
    <% } else { %>
    <div class="space-y-4">
      <% products.forEach(function(p) { %>
      <div class="bg-white rounded-2xl shadow-sm p-5">
        <div class="flex items-start justify-between gap-4 mb-4">
          <div>
            <span class="text-base font-bold text-gray-900"><%= p.model %></span>
            <span class="text-sm text-gray-500 ml-2"><%= p.name %></span>
            <span class="text-xs text-gray-400 ml-1">/ <%= p.nameEn %></span>
          </div>
          <div class="flex gap-2 shrink-0">
            <a href="/admin/<%= p.model %>/edit"
               class="text-xs border border-blue-400 text-blue-500 px-3 py-1 rounded-lg hover:bg-blue-50 transition-colors">
              编辑
            </a>
            <form method="POST" action="/admin/products/<%= p.model %>/delete"
                  onsubmit="return confirm('确认删除 <%= p.model %> <%= p.name %>？此操作不可恢复。')">
              <button type="submit"
                      class="text-xs border border-red-300 text-red-400 px-3 py-1 rounded-lg hover:bg-red-50 transition-colors">
                删除
              </button>
            </form>
          </div>
        </div>

        <!-- URL 列表 -->
        <div class="space-y-2">
          <div class="flex items-center gap-2">
            <span class="text-xs text-gray-400 w-16 shrink-0">中文版</span>
            <code class="flex-1 text-xs bg-gray-50 border rounded px-2 py-1 text-gray-700 truncate url-display"
                  data-path="/<%= p.model %>"></code>
            <button onclick="copyUrl(this)"
                    class="text-xs bg-gray-100 hover:bg-gray-200 text-gray-600 px-2 py-1 rounded transition-colors shrink-0">
              复制
            </button>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-xs text-gray-400 w-16 shrink-0">英文版</span>
            <code class="flex-1 text-xs bg-gray-50 border rounded px-2 py-1 text-gray-700 truncate url-display"
                  data-path="/<%= p.model %>?lang=en"></code>
            <button onclick="copyUrl(this)"
                    class="text-xs bg-gray-100 hover:bg-gray-200 text-gray-600 px-2 py-1 rounded transition-colors shrink-0">
              复制
            </button>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-xs text-gray-400 w-16 shrink-0">兼容旧版</span>
            <code class="flex-1 text-xs bg-gray-50 border rounded px-2 py-1 text-gray-500 truncate url-display"
                  data-path="/<%= p.model %>.html"></code>
            <button onclick="copyUrl(this)"
                    class="text-xs bg-gray-100 hover:bg-gray-200 text-gray-600 px-2 py-1 rounded transition-colors shrink-0">
              复制
            </button>
          </div>
        </div>
      </div>
      <% }); %>
    </div>
    <% } %>

  </main>

  <script>
    const domainInput = document.getElementById('domain-input');

    function updateUrls() {
      const domain = (domainInput.value || '').replace(/\/$/, '');
      document.querySelectorAll('.url-display').forEach(el => {
        el.textContent = domain + el.getAttribute('data-path');
      });
    }

    domainInput.addEventListener('input', updateUrls);
    updateUrls();

    function copyUrl(btn) {
      const code = btn.previousElementSibling;
      const text = code.textContent;
      if (!text || text.startsWith('/')) {
        alert('请先在上方输入域名');
        return;
      }
      navigator.clipboard.writeText(text).then(() => {
        const orig = btn.textContent;
        btn.textContent = '已复制 ✓';
        btn.classList.add('bg-green-100', 'text-green-600');
        setTimeout(() => {
          btn.textContent = orig;
          btn.classList.remove('bg-green-100', 'text-green-600');
        }, 1500);
      });
    }
  </script>
</body>
</html>
