<%
  const displayName = product.nameEn || 'Product';
  const displayCompany = product.companyEn || 'Company';
  const displayAddress = product.addressEn || '';
  const displayBlade = product.params.bladeEn || '—';
  const displayCartonQty = product.pkg.qtyEn || '—';
  const displayPatentName = product.patent.nameEn || '—';
  const displayPatentCertNo = product.patent.certNoEn || '—';
  const displayPatentOwner = product.patent.ownerEn || displayCompany;
  const displayPatentIssuer = product.patent.issuerEn || '—';
  const displayDesigner = product.patent.designerEn || '';
  const certificates = Array.isArray(product.certificates)
    ? product.certificates.map((cert) => ({
        ...cert,
        displayName: cert.nameEn || 'Certificate Attachment'
      }))
    : [];
%>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= product.model %> <%= displayName %> - Product Credentials</title>
  <meta name="description" content="<%= displayCompany %> <%= product.model %> <%= displayName %> product credentials, including patent documents and key specifications.">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-gray-50 min-h-screen overflow-x-hidden">

  <header class="bg-white border-b sticky top-0 z-10">
    <div class="max-w-lg mx-auto px-4 py-3 flex items-center justify-between">
      <h1 class="text-sm font-semibold text-gray-800">Product Credentials</h1>
      <span class="text-xs text-gray-400 ml-1"><%= product.model %></span>
    </div>
  </header>

  <main class="max-w-lg mx-auto px-4 py-6 space-y-6">

    <section class="bg-white rounded-2xl overflow-hidden shadow-sm">
      <div class="bg-gradient-to-br from-slate-100 to-slate-200 h-64 overflow-hidden w-full">
        <img src="/<%= product.image %>"
             alt="<%= product.model %> <%= displayName %>"
             class="w-full h-full object-cover block"
             onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'">
        <div style="display:none" class="flex-col items-center justify-center h-full text-gray-300">
          <svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1"
                  d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          <p class="text-xs mt-2">Product image coming soon</p>
        </div>
      </div>
      <div class="p-5">
        <h2 class="text-lg font-bold text-gray-900"><%= displayName %></h2>
        <p class="text-sm text-gray-500 mt-1">Model: <%= product.model %> · <%= displayCompany %></p>
      </div>
    </section>

    <section class="bg-white rounded-2xl shadow-sm p-5">
      <h3 class="text-base font-semibold text-gray-800 mb-4 flex items-center gap-2">
        <span class="w-1 h-4 bg-blue-500 rounded-full inline-block"></span>
        <span>Key Specifications</span>
      </h3>
      <div class="grid grid-cols-2 gap-3">
        <div class="bg-gray-50 rounded-xl p-3">
          <p class="text-xs text-gray-400">Battery</p>
          <p class="text-sm font-semibold mt-1"><%= product.params.battery || '—' %></p>
        </div>
        <div class="bg-gray-50 rounded-xl p-3">
          <p class="text-xs text-gray-400">Max Power</p>
          <p class="text-sm font-semibold mt-1"><%= product.params.power || '—' %></p>
        </div>
        <div class="bg-gray-50 rounded-xl p-3">
          <p class="text-xs text-gray-400">Motor Speed</p>
          <p class="text-sm font-semibold mt-1"><%= product.params.speed || '—' %></p>
        </div>
        <div class="bg-gray-50 rounded-xl p-3">
          <p class="text-xs text-gray-400">Blade Material</p>
          <p class="text-sm font-semibold mt-1"><%= displayBlade %></p>
        </div>
        <div class="bg-gray-50 rounded-xl p-3">
          <p class="text-xs text-gray-400">Charging Port</p>
          <p class="text-sm font-semibold mt-1"><%= product.params.port || '—' %></p>
        </div>
        <div class="bg-gray-50 rounded-xl p-3">
          <p class="text-xs text-gray-400">Charging Time</p>
          <p class="text-sm font-semibold mt-1 <%= product.params.chargingTime ? '' : 'text-orange-500' %>"><%= product.params.chargingTime || 'TBD' %></p>
        </div>
        <div class="bg-gray-50 rounded-xl p-3">
          <p class="text-xs text-gray-400">Production Date</p>
          <p class="text-sm font-semibold mt-1 <%= product.params.productionDate ? '' : 'text-orange-500' %>"><%= product.params.productionDate || 'Pending' %></p>
        </div>
        <div class="bg-gray-50 rounded-xl p-3">
          <p class="text-xs text-gray-400">Weight</p>
          <p class="text-sm font-semibold mt-1"><%= product.params.weight || '—' %></p>
        </div>
        <div class="bg-gray-50 rounded-xl p-3">
          <p class="text-xs text-gray-400">Dimensions</p>
          <p class="text-sm font-semibold mt-1">
            <%= product.params.dimensions || '—' %>
            <% if (product.params.dimensionsUnit) { %>
            <span class="text-xs font-normal text-gray-400"><%= product.params.dimensionsUnit %></span>
            <% } else if (product.params.dimensions) { %>
            <span class="text-xs font-normal text-orange-400">unit pending</span>
            <% } %>
          </p>
        </div>
      </div>
      <div class="mt-4 pt-4 border-t space-y-2">
        <div class="flex justify-between text-sm gap-4">
          <span class="text-gray-400">Package Size</span>
          <span class="font-medium text-gray-800 text-right"><%= product.pkg.size || '—' %></span>
        </div>
        <div class="flex justify-between text-sm gap-4">
          <span class="text-gray-400">Carton Qty</span>
          <span class="font-medium text-gray-800 text-right"><%= displayCartonQty %></span>
        </div>
        <div class="flex justify-between text-sm gap-4">
          <span class="text-gray-400">Carton Size</span>
          <span class="font-medium text-gray-800 text-right"><%= product.pkg.carton || '—' %></span>
        </div>
      </div>
    </section>

    <section class="bg-white rounded-2xl shadow-sm p-5">
      <h3 class="text-base font-semibold text-gray-800 mb-4 flex items-center gap-2">
        <span class="w-1 h-4 bg-blue-500 rounded-full inline-block"></span>
        <span>Patent Information</span>
      </h3>
      <dl class="space-y-3 text-sm">
        <div class="flex justify-between gap-4">
          <dt class="text-gray-400">Patent No.</dt>
          <dd class="font-mono font-medium text-gray-800 text-right"><%= product.patent.no || '—' %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-gray-400">Patent Name</dt>
          <dd class="font-medium text-gray-800 text-right"><%= displayPatentName %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-gray-400">Publication No.</dt>
          <dd class="font-mono font-medium text-gray-800 text-right"><%= product.patent.pubNo || '—' %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-gray-400">Certificate No.</dt>
          <dd class="font-medium text-gray-800 text-right"><%= displayPatentCertNo %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-gray-400">Patentee</dt>
          <dd class="font-medium text-gray-800 text-right"><%= displayPatentOwner %></dd>
        </div>
        <% if (displayDesigner) { %>
        <div class="flex justify-between gap-4">
          <dt class="text-gray-400">Designer</dt>
          <dd class="font-medium text-gray-800 text-right"><%= displayDesigner %></dd>
        </div>
        <% } %>
        <div class="flex justify-between gap-4">
          <dt class="text-gray-400">Application Date</dt>
          <dd class="font-medium text-gray-800 text-right"><%= product.patent.applyDate || '—' %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-gray-400">Publication Date</dt>
          <dd class="font-medium text-gray-800 text-right"><%= product.patent.pubDate || '—' %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-gray-400">Issuing Authority</dt>
          <dd class="font-medium text-gray-800 text-right"><%= displayPatentIssuer %></dd>
        </div>
        <% if (product.patent.evalDate) { %>
        <div class="flex justify-between gap-4">
          <dt class="text-gray-400">Evaluation Report Date</dt>
          <dd class="font-medium text-gray-800 text-right"><%= product.patent.evalDate %></dd>
        </div>
        <% } %>
      </dl>
    </section>

    <% if (certificates.length > 0) { %>
    <section class="bg-white rounded-2xl shadow-sm p-5">
      <h3 class="text-base font-semibold text-gray-800 mb-4 flex items-center gap-2">
        <span class="w-1 h-4 bg-blue-500 rounded-full inline-block"></span>
        <span>Certificate Attachments</span>
      </h3>
      <div class="space-y-3">
        <% certificates.forEach(function(cert) { %>
        <a href="/<%= cert.file %>" target="_blank"
           class="flex items-center gap-4 p-3 rounded-xl border hover:bg-gray-50 active:bg-gray-100 transition-colors">
          <img src="/<%= cert.thumb %>" alt="<%= cert.displayName %>"
               class="w-12 h-16 object-cover rounded border bg-gray-100 shrink-0"
               onerror="this.style.display='none'; this.nextElementSibling.classList.remove('hidden')">
          <div class="hidden w-12 h-16 bg-red-50 rounded border flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-gray-800 truncate"><%= cert.displayName %></p>
            <p class="text-xs text-gray-400 mt-0.5">PDF<% if (cert.date) { %> · <%= cert.date %><% } %></p>
          </div>
          <span class="text-xs text-blue-500 whitespace-nowrap shrink-0">View →</span>
        </a>
        <% }); %>
      </div>
    </section>
    <% } %>

    <footer class="text-center text-xs text-gray-300 pt-2 pb-8 space-y-1">
      <p><%= displayCompany %></p>
      <% if (displayAddress) { %>
      <p><%= displayAddress %></p>
      <% } %>
    </footer>

  </main>
</body>
</html>
