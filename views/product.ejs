<%
  const pageLang = lang === 'en' ? 'en' : 'zh';
  const zhCatalog = {
    'FC789-1': {
      headerTitle: '产品背书资料',
      name: '毛发修剪器',
      subtitle: '型号：FC789-1',
      imagePending: '产品图片待上传',
      params: {
        title: '核心参数',
        battery: '电池容量',
        power: '最大功率',
        speed: '电机转速',
        material: '材质',
        materialValue: '铝合金',
        blade: '刀片材质',
        bladeValue: '3铬13 不锈铁',
        port: '充电接口',
        charging: '充电时间',
        chargingValue: '5小时',
        usage: '使用时间',
        usageValue: '6~8小时',
        productionDate: '生产日期',
        productionDateValue: '见包装喷码',
        weight: '产品重量',
        cartonQty: '装箱数量',
        cartonQtyValue: '80 台/箱',
        cartonSize: '装箱尺寸'
      },
      patent: {
        title: '专利信息',
        no: '专利号',
        name: '专利名称',
        nameValue: '毛发修剪器（外观设计）',
        pubNo: '授权公告号',
        certNo: '专利证书号',
        certNoValue: '第 9621776 号',
        applyDate: '申请日',
        publicationDate: '授权公告日',
        issuer: '发证机构',
        issuerValue: '国家知识产权局',
        evalDate: '评价报告提交日'
      }
    }
  };

  const zh = zhCatalog[product.model] || {
    headerTitle: '产品背书资料',
    name: product.nameEn || '产品',
    subtitle: `型号：${product.model}`,
    imagePending: '产品图片待上传',
    params: {
      title: '核心参数',
      battery: '电池容量',
      power: '最大功率',
      speed: '电机转速',
      material: '材质',
      materialValue: product.params.materialEn || '—',
      blade: '刀片材质',
      bladeValue: product.params.bladeEn || '—',
      port: '充电接口',
      charging: '充电时间',
      chargingValue: product.params.chargingTime || '待补充',
      usage: '使用时间',
      usageValue: product.params.usageTime || '待补充',
      productionDate: '生产日期',
      productionDateValue: product.params.productionDate || '待补充',
      weight: '产品重量',
      cartonQty: '装箱数量',
      cartonQtyValue: product.pkg.qtyEn || '—',
      cartonSize: '装箱尺寸'
    },
    patent: {
      title: '专利信息',
      no: '专利号',
      name: '专利名称',
      nameValue: product.patent.nameEn || '—',
      pubNo: '授权公告号',
      certNo: '专利证书号',
      certNoValue: product.patent.certNoEn || '—',
      applyDate: '申请日',
      publicationDate: '授权公告日',
      issuer: '发证机构',
      issuerValue: product.patent.issuerEn || '—',
      evalDate: '评价报告提交日'
    }
  };

  const en = {
    headerTitle: 'Product Credentials',
    name: product.nameEn || 'Product',
    subtitle: `Model: ${product.model}`,
    imagePending: 'Product image coming soon',
    params: {
      title: 'Key Specifications',
      battery: 'Battery',
      power: 'Max Power',
      speed: 'Motor Speed',
      material: 'Material',
      materialValue: product.params.materialEn || '—',
      blade: 'Blade Material',
      bladeValue: product.params.bladeEn || '—',
      port: 'Charging Port',
      charging: 'Charging Time',
      chargingValue: product.params.chargingTime || 'TBD',
      usage: 'Usage Time',
      usageValue: product.params.usageTime || 'TBD',
      productionDate: 'Production Date',
      productionDateValue: product.params.productionDate || 'Pending',
      weight: 'Weight',
      cartonQty: 'Carton Qty',
      cartonQtyValue: product.pkg.qtyEn || '—',
      cartonSize: 'Carton Size'
    },
    patent: {
      title: 'Patent Information',
      no: 'Patent No.',
      name: 'Patent Name',
      nameValue: product.patent.nameEn || '—',
      pubNo: 'Publication No.',
      certNo: 'Certificate No.',
      certNoValue: product.patent.certNoEn || '—',
      applyDate: 'Application Date',
      publicationDate: 'Publication Date',
      issuer: 'Issuing Authority',
      issuerValue: product.patent.issuerEn || '—',
      evalDate: 'Evaluation Report Date'
    }
  };

  const copy = pageLang === 'en' ? en : zh;
  const htmlLang = pageLang === 'en' ? 'en' : 'zh-CN';
  const metaDescription = pageLang === 'en'
    ? `${copy.name} product credentials with patent information and key specifications.`
    : `${copy.name}产品背书资料，包含专利信息、核心参数等内容。`;
%>
<!DOCTYPE html>
<html lang="<%= htmlLang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= copy.name %> - <%= copy.headerTitle %></title>
  <meta name="description" content="<%= metaDescription %>">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-gray-50 min-h-screen overflow-x-hidden">

  <header class="bg-white border-b sticky top-0 z-10">
    <div class="max-w-lg mx-auto px-4 py-3 flex items-center justify-between">
      <h1 class="text-sm font-semibold text-gray-800"><%= copy.headerTitle %></h1>
      <span class="text-xs text-gray-400 ml-1"><%= product.model %></span>
    </div>
  </header>

  <main class="max-w-lg mx-auto px-4 py-6 space-y-6">

    <section class="bg-white rounded-2xl overflow-hidden shadow-sm">
      <div class="bg-gradient-to-br from-slate-100 to-slate-200 h-64 overflow-hidden w-full">
        <img src="/<%= product.image %>"
             alt="<%= copy.name %>"
             class="w-full h-full object-cover block"
             onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'">
        <div style="display:none" class="flex-col items-center justify-center h-full text-gray-300">
          <svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1"
                  d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          <p class="text-xs mt-2"><%= copy.imagePending %></p>
        </div>
      </div>
      <div class="p-5">
        <h2 class="text-lg font-bold text-gray-900"><%= copy.name %></h2>
        <p class="text-sm text-gray-500 mt-1"><%= copy.subtitle %></p>
      </div>
    </section>

    <section class="bg-white rounded-2xl shadow-sm p-5">
      <h3 class="text-base font-semibold text-gray-800 mb-4 flex items-center gap-2">
        <span class="w-1 h-4 bg-blue-500 rounded-full inline-block"></span>
        <span><%= copy.params.title %></span>
      </h3>
      <div class="grid grid-cols-2 gap-3">
        <div class="bg-gray-50 rounded-xl p-3">
          <p class="text-xs text-gray-400"><%= copy.params.battery %></p>
          <p class="text-sm font-semibold mt-1"><%= product.params.battery || '—' %></p>
        </div>
        <div class="bg-gray-50 rounded-xl p-3">
          <p class="text-xs text-gray-400"><%= copy.params.power %></p>
          <p class="text-sm font-semibold mt-1"><%= product.params.power || '—' %></p>
        </div>
        <div class="bg-gray-50 rounded-xl p-3">
          <p class="text-xs text-gray-400"><%= copy.params.speed %></p>
          <p class="text-sm font-semibold mt-1"><%= product.params.speed || '—' %></p>
        </div>
        <div class="bg-gray-50 rounded-xl p-3">
          <p class="text-xs text-gray-400"><%= copy.params.material %></p>
          <p class="text-sm font-semibold mt-1"><%= copy.params.materialValue %></p>
        </div>
        <div class="bg-gray-50 rounded-xl p-3">
          <p class="text-xs text-gray-400"><%= copy.params.blade %></p>
          <p class="text-sm font-semibold mt-1"><%= copy.params.bladeValue %></p>
        </div>
        <div class="bg-gray-50 rounded-xl p-3">
          <p class="text-xs text-gray-400"><%= copy.params.port %></p>
          <p class="text-sm font-semibold mt-1"><%= product.params.port || '—' %></p>
        </div>
        <div class="bg-gray-50 rounded-xl p-3">
          <p class="text-xs text-gray-400"><%= copy.params.charging %></p>
          <p class="text-sm font-semibold mt-1"><%= copy.params.chargingValue %></p>
        </div>
        <div class="bg-gray-50 rounded-xl p-3">
          <p class="text-xs text-gray-400"><%= copy.params.usage %></p>
          <p class="text-sm font-semibold mt-1"><%= copy.params.usageValue %></p>
        </div>
        <div class="bg-gray-50 rounded-xl p-3">
          <p class="text-xs text-gray-400"><%= copy.params.productionDate %></p>
          <p class="text-sm font-semibold mt-1"><%= copy.params.productionDateValue %></p>
        </div>
        <div class="bg-gray-50 rounded-xl p-3">
          <p class="text-xs text-gray-400"><%= copy.params.weight %></p>
          <p class="text-sm font-semibold mt-1"><%= product.params.weight || '—' %></p>
        </div>
      </div>
      <div class="mt-4 pt-4 border-t space-y-2">
        <div class="flex justify-between text-sm gap-4">
          <span class="text-gray-400"><%= copy.params.cartonQty %></span>
          <span class="font-medium text-gray-800 text-right"><%= copy.params.cartonQtyValue %></span>
        </div>
        <div class="flex justify-between text-sm gap-4">
          <span class="text-gray-400"><%= copy.params.cartonSize %></span>
          <span class="font-medium text-gray-800 text-right"><%= product.pkg.carton || '—' %></span>
        </div>
      </div>
    </section>

    <section class="bg-white rounded-2xl shadow-sm p-5">
      <h3 class="text-base font-semibold text-gray-800 mb-4 flex items-center gap-2">
        <span class="w-1 h-4 bg-blue-500 rounded-full inline-block"></span>
        <span><%= copy.patent.title %></span>
      </h3>
      <dl class="space-y-3 text-sm">
        <div class="flex justify-between gap-4">
          <dt class="text-gray-400"><%= copy.patent.no %></dt>
          <dd class="font-mono font-medium text-gray-800 text-right"><%= product.patent.no || '—' %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-gray-400"><%= copy.patent.name %></dt>
          <dd class="font-medium text-gray-800 text-right"><%= copy.patent.nameValue %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-gray-400"><%= copy.patent.pubNo %></dt>
          <dd class="font-mono font-medium text-gray-800 text-right"><%= product.patent.pubNo || '—' %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-gray-400"><%= copy.patent.certNo %></dt>
          <dd class="font-medium text-gray-800 text-right"><%= copy.patent.certNoValue %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-gray-400"><%= copy.patent.applyDate %></dt>
          <dd class="font-medium text-gray-800 text-right"><%= product.patent.applyDate || '—' %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-gray-400"><%= copy.patent.publicationDate %></dt>
          <dd class="font-medium text-gray-800 text-right"><%= product.patent.pubDate || '—' %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-gray-400"><%= copy.patent.issuer %></dt>
          <dd class="font-medium text-gray-800 text-right"><%= copy.patent.issuerValue %></dd>
        </div>
        <% if (product.patent.evalDate) { %>
        <div class="flex justify-between gap-4">
          <dt class="text-gray-400"><%= copy.patent.evalDate %></dt>
          <dd class="font-medium text-gray-800 text-right"><%= product.patent.evalDate %></dd>
        </div>
        <% } %>
      </dl>
    </section>

  </main>
</body>
</html>
