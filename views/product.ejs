<%
  const zhCatalog = {
    'FC789-1': {
      headerTitle: '产品背书资料',
      name: '毛发修剪器',
      subtitle: '型号：FC789-1',
      imagePending: '产品图片待上传',
      params: {
        title: '核心参数',
        battery: '电池容量',
        power: '最大功率',
        speed: '电机转速',
        blade: '刀片材质',
        bladeValue: '3铬13 不锈铁',
        port: '充电接口',
        charging: '充电时间',
        chargingValue: '5小时',
        usage: '使用时间',
        usageValue: '6~8小时',
        productionDate: '生产日期',
        productionDateValue: '见包装喷码',
        weight: '产品重量',
        cartonQty: '装箱数量',
        cartonQtyValue: '80 台/箱',
        cartonSize: '装箱尺寸'
      },
      patent: {
        title: '专利信息',
        no: '专利号',
        name: '专利名称',
        nameValue: '毛发修剪器（外观设计）',
        pubNo: '授权公告号',
        certNo: '专利证书号',
        certNoValue: '第 9621776 号',
        applyDate: '申请日',
        publicationDate: '授权公告日',
        issuer: '发证机构',
        issuerValue: '国家知识产权局',
        evalDate: '评价报告提交日'
      },
      attachments: {
        title: '证书附件',
        names: [
          '外观设计专利证书',
          '外观设计专利权评价报告'
        ],
        view: '查看 →'
      }
    }
  };

  const zh = zhCatalog[product.model] || {
    headerTitle: '产品背书资料',
    name: product.nameEn || '产品',
    subtitle: `型号：${product.model}`,
    imagePending: '产品图片待上传',
    params: {
      title: '核心参数',
      battery: '电池容量',
      power: '最大功率',
      speed: '电机转速',
      blade: '刀片材质',
      bladeValue: product.params.bladeEn || '—',
      port: '充电接口',
      charging: '充电时间',
      chargingValue: product.params.chargingTime || '待补充',
      usage: '使用时间',
      usageValue: product.params.usageTime || '待补充',
      productionDate: '生产日期',
      productionDateValue: product.params.productionDate || '待补充',
      weight: '产品重量',
      cartonQty: '装箱数量',
      cartonQtyValue: product.pkg.qtyEn || '—',
      cartonSize: '装箱尺寸'
    },
    patent: {
      title: '专利信息',
      no: '专利号',
      name: '专利名称',
      nameValue: product.patent.nameEn || '—',
      pubNo: '授权公告号',
      certNo: '专利证书号',
      certNoValue: product.patent.certNoEn || '—',
      applyDate: '申请日',
      publicationDate: '授权公告日',
      issuer: '发证机构',
      issuerValue: product.patent.issuerEn || '—',
      evalDate: '评价报告提交日'
    },
    attachments: {
      title: '证书附件',
      names: [],
      view: '查看 →'
    }
  };

  const en = {
    headerTitle: 'Product Credentials',
    name: product.nameEn || 'Product',
    subtitle: `Model: ${product.model}`,
    imagePending: 'Product image coming soon',
    params: {
      title: 'Key Specifications',
      battery: 'Battery',
      power: 'Max Power',
      speed: 'Motor Speed',
      blade: 'Blade Material',
      bladeValue: product.params.bladeEn || '—',
      port: 'Charging Port',
      charging: 'Charging Time',
      chargingValue: product.params.chargingTime || 'TBD',
      usage: 'Usage Time',
      usageValue: product.params.usageTime || 'TBD',
      productionDate: 'Production Date',
      productionDateValue: product.params.productionDate || 'Pending',
      weight: 'Weight',
      cartonQty: 'Carton Qty',
      cartonQtyValue: product.pkg.qtyEn || '—',
      cartonSize: 'Carton Size'
    },
    patent: {
      title: 'Patent Information',
      no: 'Patent No.',
      name: 'Patent Name',
      nameValue: product.patent.nameEn || '—',
      pubNo: 'Publication No.',
      certNo: 'Certificate No.',
      certNoValue: product.patent.certNoEn || '—',
      applyDate: 'Application Date',
      publicationDate: 'Publication Date',
      issuer: 'Issuing Authority',
      issuerValue: product.patent.issuerEn || '—',
      evalDate: 'Evaluation Report Date'
    },
    attachments: {
      title: 'Certificate Attachments',
      names: (product.certificates || []).map((cert) => cert.nameEn || 'Certificate Attachment'),
      view: 'View →'
    }
  };
  const certificates = Array.isArray(product.certificates)
    ? product.certificates.map((cert, index) => ({
        ...cert,
        displayNameEn: cert.nameEn || 'Certificate Attachment',
        displayNameZh: zh.attachments.names[index] || cert.nameEn || '证书附件'
      }))
    : [];
%>
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= zh.name %> - <%= zh.headerTitle %></title>
  <meta name="description" content="<%= zh.name %>产品背书资料，包含专利证书、核心参数等信息。">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-gray-50 min-h-screen overflow-x-hidden">

  <header class="bg-white border-b sticky top-0 z-10">
    <div class="max-w-lg mx-auto px-4 py-3 flex items-center justify-between">
      <h1 id="header-title" class="text-sm font-semibold text-gray-800"><%= zh.headerTitle %></h1>
      <div class="flex items-center gap-2">
        <button onclick="switchLang('zh')" id="btn-zh" type="button" class="text-xs px-2 py-0.5 rounded-full border border-gray-300 text-gray-500 hover:bg-gray-50 transition-colors">中文</button>
        <button onclick="switchLang('en')" id="btn-en" type="button" class="text-xs px-2 py-0.5 rounded-full border border-gray-300 text-gray-500 hover:bg-gray-50 transition-colors">EN</button>
        <span class="text-xs text-gray-400 ml-1"><%= product.model %></span>
      </div>
    </div>
  </header>

  <main class="max-w-lg mx-auto px-4 py-6 space-y-6">

    <section class="bg-white rounded-2xl overflow-hidden shadow-sm">
      <div class="bg-gradient-to-br from-slate-100 to-slate-200 h-64 overflow-hidden w-full">
        <img src="/<%= product.image %>"
             id="product-image"
             alt="<%= zh.name %>"
             class="w-full h-full object-cover block"
             onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'">
        <div style="display:none" class="flex-col items-center justify-center h-full text-gray-300">
          <svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1"
                  d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          <p id="image-pending" class="text-xs mt-2"><%= zh.imagePending %></p>
        </div>
      </div>
      <div class="p-5">
        <h2 id="product-name" class="text-lg font-bold text-gray-900"><%= zh.name %></h2>
        <p id="product-subtitle" class="text-sm text-gray-500 mt-1"><%= zh.subtitle %></p>
      </div>
    </section>

    <section class="bg-white rounded-2xl shadow-sm p-5">
      <h3 class="text-base font-semibold text-gray-800 mb-4 flex items-center gap-2">
        <span class="w-1 h-4 bg-blue-500 rounded-full inline-block"></span>
        <span id="specs-title"><%= zh.params.title %></span>
      </h3>
      <div class="grid grid-cols-2 gap-3">
        <div class="bg-gray-50 rounded-xl p-3">
          <p id="label-battery" class="text-xs text-gray-400"><%= zh.params.battery %></p>
          <p class="text-sm font-semibold mt-1"><%= product.params.battery || '—' %></p>
        </div>
        <div class="bg-gray-50 rounded-xl p-3">
          <p id="label-power" class="text-xs text-gray-400"><%= zh.params.power %></p>
          <p class="text-sm font-semibold mt-1"><%= product.params.power || '—' %></p>
        </div>
        <div class="bg-gray-50 rounded-xl p-3">
          <p id="label-speed" class="text-xs text-gray-400"><%= zh.params.speed %></p>
          <p class="text-sm font-semibold mt-1"><%= product.params.speed || '—' %></p>
        </div>
        <div class="bg-gray-50 rounded-xl p-3">
          <p id="label-blade" class="text-xs text-gray-400"><%= zh.params.blade %></p>
          <p id="value-blade" class="text-sm font-semibold mt-1"><%= zh.params.bladeValue %></p>
        </div>
        <div class="bg-gray-50 rounded-xl p-3">
          <p id="label-port" class="text-xs text-gray-400"><%= zh.params.port %></p>
          <p class="text-sm font-semibold mt-1"><%= product.params.port || '—' %></p>
        </div>
        <div class="bg-gray-50 rounded-xl p-3">
          <p id="label-charging" class="text-xs text-gray-400"><%= zh.params.charging %></p>
          <p id="value-charging" class="text-sm font-semibold mt-1"><%= zh.params.chargingValue %></p>
        </div>
        <div class="bg-gray-50 rounded-xl p-3">
          <p id="label-usage" class="text-xs text-gray-400"><%= zh.params.usage %></p>
          <p id="value-usage" class="text-sm font-semibold mt-1"><%= zh.params.usageValue %></p>
        </div>
        <div class="bg-gray-50 rounded-xl p-3">
          <p id="label-production-date" class="text-xs text-gray-400"><%= zh.params.productionDate %></p>
          <p id="value-production-date" class="text-sm font-semibold mt-1"><%= zh.params.productionDateValue %></p>
        </div>
        <div class="bg-gray-50 rounded-xl p-3">
          <p id="label-weight" class="text-xs text-gray-400"><%= zh.params.weight %></p>
          <p class="text-sm font-semibold mt-1"><%= product.params.weight || '—' %></p>
        </div>
      </div>
      <div class="mt-4 pt-4 border-t space-y-2">
        <div class="flex justify-between text-sm gap-4">
          <span id="label-carton-qty" class="text-gray-400"><%= zh.params.cartonQty %></span>
          <span id="value-carton-qty" class="font-medium text-gray-800 text-right"><%= zh.params.cartonQtyValue %></span>
        </div>
        <div class="flex justify-between text-sm gap-4">
          <span id="label-carton-size" class="text-gray-400"><%= zh.params.cartonSize %></span>
          <span class="font-medium text-gray-800 text-right"><%= product.pkg.carton || '—' %></span>
        </div>
      </div>
    </section>

    <section class="bg-white rounded-2xl shadow-sm p-5">
      <h3 class="text-base font-semibold text-gray-800 mb-4 flex items-center gap-2">
        <span class="w-1 h-4 bg-blue-500 rounded-full inline-block"></span>
        <span id="patent-title"><%= zh.patent.title %></span>
      </h3>
      <dl class="space-y-3 text-sm">
        <div class="flex justify-between gap-4">
          <dt id="label-patent-no" class="text-gray-400"><%= zh.patent.no %></dt>
          <dd class="font-mono font-medium text-gray-800 text-right"><%= product.patent.no || '—' %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt id="label-patent-name" class="text-gray-400"><%= zh.patent.name %></dt>
          <dd id="value-patent-name" class="font-medium text-gray-800 text-right"><%= zh.patent.nameValue %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt id="label-pub-no" class="text-gray-400"><%= zh.patent.pubNo %></dt>
          <dd class="font-mono font-medium text-gray-800 text-right"><%= product.patent.pubNo || '—' %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt id="label-cert-no" class="text-gray-400"><%= zh.patent.certNo %></dt>
          <dd id="value-cert-no" class="font-medium text-gray-800 text-right"><%= zh.patent.certNoValue %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt id="label-apply-date" class="text-gray-400"><%= zh.patent.applyDate %></dt>
          <dd class="font-medium text-gray-800 text-right"><%= product.patent.applyDate || '—' %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt id="label-publication-date" class="text-gray-400"><%= zh.patent.publicationDate %></dt>
          <dd class="font-medium text-gray-800 text-right"><%= product.patent.pubDate || '—' %></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt id="label-issuer" class="text-gray-400"><%= zh.patent.issuer %></dt>
          <dd id="value-issuer" class="font-medium text-gray-800 text-right"><%= zh.patent.issuerValue %></dd>
        </div>
        <% if (product.patent.evalDate) { %>
        <div class="flex justify-between gap-4">
          <dt id="label-eval-date" class="text-gray-400"><%= zh.patent.evalDate %></dt>
          <dd class="font-medium text-gray-800 text-right"><%= product.patent.evalDate %></dd>
        </div>
        <% } %>
      </dl>
    </section>

    <% if (certificates.length > 0) { %>
    <section class="bg-white rounded-2xl shadow-sm p-5">
      <h3 class="text-base font-semibold text-gray-800 mb-4 flex items-center gap-2">
        <span class="w-1 h-4 bg-blue-500 rounded-full inline-block"></span>
        <span id="attachments-title"><%= zh.attachments.title %></span>
      </h3>
      <div class="space-y-3">
        <% certificates.forEach(function(cert, index) { %>
        <a href="/<%= cert.file %>" target="_blank"
           class="flex items-center gap-4 p-3 rounded-xl border hover:bg-gray-50 active:bg-gray-100 transition-colors">
          <img src="/<%= cert.thumb %>" alt="<%= cert.displayNameZh %>"
               class="w-12 h-16 object-cover rounded border bg-gray-100 shrink-0"
               onerror="this.style.display='none'; this.nextElementSibling.classList.remove('hidden')">
          <div class="hidden w-12 h-16 bg-red-50 rounded border flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-gray-800 truncate attachment-name"
               data-zh="<%= cert.displayNameZh %>" data-en="<%= cert.displayNameEn %>"><%= cert.displayNameZh %></p>
            <p class="text-xs text-gray-400 mt-0.5">PDF<% if (cert.date) { %> · <%= cert.date %><% } %></p>
          </div>
          <span class="text-xs text-blue-500 whitespace-nowrap shrink-0 attachment-view"><%= zh.attachments.view %></span>
        </a>
        <% }); %>
      </div>
    </section>
    <% } %>

  </main>

  <script>
    const I18N = {
      zh: <%- JSON.stringify(zh) %>,
      en: <%- JSON.stringify(en) %>
    };

    function switchLang(lang) {
      const normalizedLang = lang === 'en' ? 'en' : 'zh';
      const copy = I18N[normalizedLang];
      const url = new URL(window.location.href);
      url.searchParams.set('lang', normalizedLang);
      if (url.toString() !== window.location.href) {
        window.history.replaceState({}, '', url);
      }
      document.documentElement.lang = normalizedLang === 'zh' ? 'zh-CN' : 'en';
      document.title = `${copy.name} - ${copy.headerTitle}`;

      document.getElementById('header-title').textContent = copy.headerTitle;
      document.getElementById('product-name').textContent = copy.name;
      document.getElementById('product-subtitle').textContent = copy.subtitle;
      document.getElementById('product-image').alt = `${copy.name} ${copy.headerTitle}`;
      document.getElementById('image-pending').textContent = copy.imagePending;

      document.getElementById('specs-title').textContent = copy.params.title;
      document.getElementById('label-battery').textContent = copy.params.battery;
      document.getElementById('label-power').textContent = copy.params.power;
      document.getElementById('label-speed').textContent = copy.params.speed;
      document.getElementById('label-blade').textContent = copy.params.blade;
      document.getElementById('value-blade').textContent = copy.params.bladeValue;
      document.getElementById('label-port').textContent = copy.params.port;
      document.getElementById('label-charging').textContent = copy.params.charging;
      document.getElementById('value-charging').textContent = copy.params.chargingValue;
      document.getElementById('label-usage').textContent = copy.params.usage;
      document.getElementById('value-usage').textContent = copy.params.usageValue;
      document.getElementById('label-production-date').textContent = copy.params.productionDate;
      document.getElementById('value-production-date').textContent = copy.params.productionDateValue;
      document.getElementById('label-weight').textContent = copy.params.weight;
      document.getElementById('label-carton-qty').textContent = copy.params.cartonQty;
      document.getElementById('value-carton-qty').textContent = copy.params.cartonQtyValue;
      document.getElementById('label-carton-size').textContent = copy.params.cartonSize;

      document.getElementById('patent-title').textContent = copy.patent.title;
      document.getElementById('label-patent-no').textContent = copy.patent.no;
      document.getElementById('label-patent-name').textContent = copy.patent.name;
      document.getElementById('value-patent-name').textContent = copy.patent.nameValue;
      document.getElementById('label-pub-no').textContent = copy.patent.pubNo;
      document.getElementById('label-cert-no').textContent = copy.patent.certNo;
      document.getElementById('value-cert-no').textContent = copy.patent.certNoValue;
      document.getElementById('label-apply-date').textContent = copy.patent.applyDate;
      document.getElementById('label-publication-date').textContent = copy.patent.publicationDate;
      document.getElementById('label-issuer').textContent = copy.patent.issuer;
      document.getElementById('value-issuer').textContent = copy.patent.issuerValue;
      const evalDateLabel = document.getElementById('label-eval-date');
      if (evalDateLabel) {
        evalDateLabel.textContent = copy.patent.evalDate;
      }

      const attachmentsTitle = document.getElementById('attachments-title');
      if (attachmentsTitle) {
        attachmentsTitle.textContent = copy.attachments.title;
      }
      document.querySelectorAll('.attachment-name').forEach((el) => {
        el.textContent = lang === 'zh' ? el.dataset.zh : el.dataset.en;
      });
      document.querySelectorAll('.attachment-view').forEach((el) => {
        el.textContent = copy.attachments.view;
      });
      const btnZh = document.getElementById('btn-zh');
      const btnEn = document.getElementById('btn-en');
      const isZh = normalizedLang === 'zh';
      btnZh.classList.toggle('font-semibold', isZh);
      btnZh.classList.toggle('border-blue-400', isZh);
      btnZh.classList.toggle('text-blue-500', isZh);
      btnEn.classList.toggle('font-semibold', !isZh);
      btnEn.classList.toggle('border-blue-400', !isZh);
      btnEn.classList.toggle('text-blue-500', !isZh);
    }

    (function () {
      const urlLang = new URLSearchParams(location.search).get('lang');
      switchLang(urlLang === 'zh' ? 'zh' : 'en');
    })();
  </script>
</body>
</html>
